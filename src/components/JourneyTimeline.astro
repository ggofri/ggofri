---

<section id="work" class="py-16">
  <div class="mb-12">
    <h2 class="text-lg font-bold mb-2">work</h2>
    <p class="text-sm text-muted-foreground">ai systems at scale — built, led, grown</p>
  </div>

  <div class="space-y-0">
    {roles.map((r) => (
      <div class="py-6 border-b border-border/50 last:border-b-0">
        <div class="flex items-baseline justify-between gap-4 mb-2">
          <div class="font-semibold text-base">
            {r.orgUrl ? (
              <a href={r.orgUrl} target="_blank" rel="noopener noreferrer" class="hover:opacity-70 transition-opacity">
                {r.org} ↗
              </a>
            ) : (
              r.org
            )}
            <span class="font-normal text-muted-foreground ml-2 text-sm">{r.role}</span>
          </div>
          {r.period && (
            <span class="text-xs text-muted-foreground flex-shrink-0">{r.period}</span>
          )}
        </div>
        <div class="space-y-1">
          {r.lines.map((line) => (
            <p class="text-sm text-muted-foreground leading-relaxed">{line}</p>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
